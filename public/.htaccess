<IfModule mod_rewrite.c>
  Options -MultiViews
  RewriteEngine On
  RewriteBase /

  # API routing: redirect /api/something to api.php?route=something
  RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]

  # React SPA routing: if file doesn't exist, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html [QSA,L]
</IfModule>
